# The compute script reads DATABASE_URL from the PROJECT ROOT .env file
# (../.env relative to this folder), not from here. This file is only a
# reminder of the variable it needs.
#
# DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/procurement_analytics?schema=public"
#
# The script strips the "?schema=public" query param before passing the URL
# to psycopg2 (libpq does not understand that Prisma-specific param).
